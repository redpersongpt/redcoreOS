{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Strict */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Paths */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/*"],
      "@redcore/shared-schema": ["../../packages/tuning-shared-schema/src"],
      "@redcore/shared-schema/*": ["../../packages/tuning-shared-schema/src/*"],
      "@redcore/system-analyzer": ["../../packages/system-analyzer/src"],
      "@redcore/system-analyzer/*": ["../../packages/system-analyzer/src/*"]
    }
  },
  "include": ["src/renderer"]
}
