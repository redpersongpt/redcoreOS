{
  "name": "@redcore-os/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "redcore OS desktop app (Tauri)",
  "author": {
    "name": "redcore",
    "email": "REDACTED_EMAIL"
  },
  "homepage": "https://redcoreos.net",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "tauri:dev": "cargo tauri dev --config src-tauri/tauri.conf.json",
    "tauri:build": "cargo tauri build --config src-tauri/tauri.conf.production.json",
    "audit:questionnaire": "node test/questionnaire-invariants.mjs && tsx test/questionnaire-execution-audit.ts",
    "audit:verification": "tsx test/verification-matrix.ts --check --outputDir ../../artifacts/os-verification",
    "verify:matrix": "tsx test/verification-matrix.ts",
    "certify:windows": "tsx test/windows-certification-harness.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
