{
  "name": "@redcore-os/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "redcore OS — In-place Windows transformation tool. Machine-aware, guided, fully reversible.",
  "author": {
    "name": "redcore",
    "email": "REDACTED_EMAIL"
  },
  "homepage": "https://redcoreos.net",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:renderer && node -e \"let h=require('fs').readFileSync('dist/renderer/index.html','utf8');h=h.replace(/ crossorigin/g,'');require('fs').writeFileSync('dist/renderer/index.html',h)\" && pnpm build:main && pnpm build:preload",
    "build:renderer": "vite build",
    "build:main": "tsc --project tsconfig.main.json",
    "build:preload": "tsc --project tsconfig.preload.json",
    "audit:questionnaire": "node test/questionnaire-invariants.mjs && tsx test/questionnaire-execution-audit.ts",
    "typecheck": "tsc --noEmit",
    "start": "electron dist/main/index.js",
    "dist": "bash ../../scripts/sync-desktop-brand-assets.sh && electron-builder --win --x64 --publish never"
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "net.redcoreos.os",
    "productName": "redcore OS",
    "copyright": "Copyright © 2026 redcore",
    "buildVersion": "0.1.0",
    "directories": {
      "output": "dist/installers",
      "buildResources": "resources"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../services/os-service/target/release/redcore-os-service.exe",
        "to": "redcore-os-service.exe"
      },
      {
        "from": "resources/redcore-icon.png",
        "to": "redcore-icon.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/redcore-icon.ico",
      "executableName": "redcore-os",
      "legalTrademarks": "redcore",
      "publisherName": "redcore",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "artifactName": "redcore-os-setup.${ext}",
      "installerIcon": "resources/redcore-icon.ico",
      "uninstallerIcon": "resources/redcore-icon.ico",
      "installerHeaderIcon": "resources/redcore-icon.ico",
      "shortcutName": "redcore OS",
      "uninstallDisplayName": "redcore OS",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "asar": true,
    "compression": "maximum",
    "removePackageScripts": true,
    "removePackageKeywords": true
  }
}
