{
  "name": "redcore-os",
  "version": "0.1.0",
  "private": true,
  "description": "Premium in-place Windows transformation wizard",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @redcore-os/desktop dev",
