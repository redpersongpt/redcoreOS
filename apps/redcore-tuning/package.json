{
  "name": "redcore-tuning",
  "version": "0.1.0",
  "private": true,
  "description": "Premium Windows optimization platform with cloud-backed licensing",
  "author": "redcore",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @redcore/desktop dev",
    "dev:api": "pnpm --filter @redcore/cloud-api dev",
    "dev:web": "pnpm --filter @redcore/website dev",
    "build": "pnpm -r build",
    "build:desktop": "pnpm --filter @redcore/desktop build",
    "build:api": "pnpm --filter @redcore/cloud-api build",
    "build:web": "pnpm --filter @redcore/website build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean"
  }
}
