{
  "name": "redcore-eco",
  "version": "1.0.0",
  "private": true,
  "description": "redcore ecosystem monorepo — Web + Tuning + OS",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:web": "pnpm --filter redcore-web dev",
    "build:web": "pnpm --filter redcore-web build",
    "start:web": "pnpm --filter redcore-web start",
    "dev:tuning": "pnpm --filter @redcore/desktop dev",
    "build:tuning": "pnpm --filter @redcore/desktop build",
    "dev:os": "pnpm --filter @redcore-os/desktop dev",
    "build:os": "pnpm --filter @redcore-os/desktop build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "build": "pnpm -r build"
  }
}
