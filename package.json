{
  "name": "redcore-eco",
  "version": "1.0.0",
  "private": true,
  "description": "redcore ecosystem — Web + Tuning + OS",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build",
    "start:web": "pnpm --dir apps/web start",
    "dev:tuning": "pnpm --filter @redcore/desktop dev",
    "build:tuning": "pnpm --filter @redcore/desktop build",
    "dev:os": "pnpm --filter @redcore-os/desktop dev",
    "build:os": "pnpm --filter @redcore-os/desktop build",
    "sync:os:wizard": "pnpm --dir apps/os-desktop exec tsx ../../scripts/sync-os-wizard-metadata.ts",
    "check:os:wizard": "pnpm --dir apps/os-desktop exec tsx ../../scripts/sync-os-wizard-metadata.ts --check",
    "build:os:apbx": "pnpm --dir apps/os-desktop exec tsx ../../scripts/build-os-apbx-package.ts",
    "validate:os:parity": "node scripts/validate-action-parity.mjs",
    "verify": "node scripts/validate-action-parity.mjs --quiet && echo '  parity: pass' && pnpm typecheck && echo '  typecheck: pass'",
    "verify:full": "node scripts/validate-action-parity.mjs && pnpm typecheck",
    "build:os:wizard": "node scripts/build-os-wizard-package.mjs",
    "dev:cloud-api": "pnpm --filter @redcore/cloud-api dev",
    "build:cloud-api": "pnpm --filter @redcore/cloud-api build",
    "start:cloud-api": "pnpm --filter @redcore/cloud-api start",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "build": "pnpm -r build"
  }
}
