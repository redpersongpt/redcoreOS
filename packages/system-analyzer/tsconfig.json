{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@redcore/shared-schema": ["../tuning-shared-schema/src/index.ts"],
      "@redcore/shared-schema/*": ["../tuning-shared-schema/src/*.ts"]
    }
  },
  "include": ["src/**/*"]
}
